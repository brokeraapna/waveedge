<!-- ABOUT PAGE -->
<div class="page" id="page-about">
  <div class="about-wrap">
    <div class="about-section">
      <h2 class="about-h">How AI Smart Signal Works</h2>
      <p class="about-p">AI Smart Signal applies the classic MACD (12, 26, 9) indicator across six timeframes simultaneously, giving traders a complete picture from long-term trend to intraday momentum.</p>
      <p class="about-p">The MACD line (EMA-12 minus EMA-26) is compared against its 9-period signal line. A crossover above generates a <strong style="color:var(--green)">BUY</strong> signal; below generates a <strong style="color:var(--red)">SELL</strong>. The zero line context indicates whether the overall momentum is bullish or bearish.</p>
    </div>
    <div class="about-section">
      <h2 class="about-h">Timeframe Reference</h2>
      <table class="about-table">
        <thead><tr><th>Timeframe</th><th>Best For</th><th>Tier</th></tr></thead>
        <tbody>
          <tr><td>Monthly</td><td>Long-term position trades, macro trend</td><td style="color:var(--green);font-family:var(--mono);font-size:11px">FREE</td></tr>
          <tr><td>Weekly</td><td>Swing trades, multi-week holds</td><td style="color:var(--green);font-family:var(--mono);font-size:11px">FREE</td></tr>
          <tr><td>Daily</td><td>Positional trades, 1-5 day setups</td><td style="color:var(--green);font-family:var(--mono);font-size:11px">FREE</td></tr>
          <tr><td>75 Min</td><td>Short-term swing, overnight positions</td><td style="color:var(--gold);font-family:var(--mono);font-size:11px">PRO ⚡</td></tr>
          <tr><td>15 Min</td><td>Intraday trading, breakout entries</td><td style="color:var(--gold);font-family:var(--mono);font-size:11px">PRO ⚡</td></tr>
          <tr><td>5 Min</td><td>Scalping, quick intraday moves</td><td style="color:var(--gold);font-family:var(--mono);font-size:11px">PRO ⚡</td></tr>
        </tbody>
      </table>
    </div>
    <div class="about-section">
      <h2 class="about-h">Signal Interpretation</h2>
      <p class="about-p">A <strong style="color:var(--green)">BUY</strong> signal above zero is the strongest bullish setup. A <strong style="color:var(--red)">SELL</strong> below zero is the strongest bearish signal. Crossovers near the zero line carry less conviction and require additional confirmation.</p>
    </div>
  </div>
</div>

<script>
// ── State ──────────────────────────────────────────────────────────────────────
var isPaid = false;
var scrips = ["AAPL","TSLA","NVDA","MSFT","RELIANCE","INFY","SBIN","TATAMOTORS","QQQ","SPY","AMZN","META"];
var allData = {};
var currentPage = 'home';

var TIMEFRAMES = [
  {id:"monthly",label:"Monthly",paid:false,bars:60, tfSeed:100},
  {id:"weekly", label:"Weekly", paid:false,bars:80, tfSeed:200},
  {id:"daily",  label:"Daily",  paid:false,bars:120,tfSeed:300},
  {id:"tf75",   label:"75 Min",paid:true, bars:150,tfSeed:400},
  {id:"tf15",   label:"15 Min",paid:true, bars:200,tfSeed:500},
  {id:"tf5",    label:"5 Min", paid:true, bars:300,tfSeed:600}
];

// ── MACD Engine ───────────────────────────────────────────────────────────────
function emaCalc(data, period) {
  if (data.length < period) return [];
  var k = 2 / (period + 1);
  var val = 0;
  for (var i = 0; i < period; i++) val += data[i];
  val /= period;
  var result = [val];
  for (var i = period; i < data.length; i++) {
    val = data[i] * k + val * (1 - k);
    result.push(val);
  }
  return result;
}

function computeMACD(closes) {
  if (closes.length < 35) return null;
  var e12 = emaCalc(closes, 12);
  var e26 = emaCalc(closes, 26);
  var macdLine = [];
  for (var i = 0; i < e26.length; i++) macdLine.push(e12[i + 11] - e26[i]);
  var sigLine = emaCalc(macdLine, 9);
  var mv = macdLine[macdLine.length - 1];
  var sv = sigLine[sigLine.length - 1];
  var pm = macdLine[macdLine.length - 2] !== undefined ? macdLine[macdLine.length - 2] : mv;
  var ps = sigLine[sigLine.length - 2] !== undefined ? sigLine[sigLine.length - 2] : sv;
  return {macdVal:mv, sigVal:sv, histogram:mv-sv, prevMacd:pm, prevSig:ps};
}

function getSignal(macd) {
  if (!macd) return {signal:"—",zero:"—",histogram:0};
  var zero = macd.macdVal > 0 ? "ABOVE" : "BELOW";
  var signal = "NEUTRAL";
  if (macd.macdVal > macd.sigVal) signal = "BUY";
  if (macd.macdVal < macd.sigVal) signal = "SELL";
  return {signal:signal, zero:zero, histogram:macd.histogram, macdVal:macd.macdVal, sigVal:macd.sigVal};
}

function rng(s) { var x = Math.sin(s * 9301 + 49297) * 233280; return x - Math.floor(x); }

function generatePrices(tSeed, tfSeed, count) {
  var prices = [];
  var price = 450 + (tSeed % 80) - 40;
  for (var i = 0; i < count; i++) {
    var r1 = rng(tSeed * 0.37 + tfSeed * 0.13 + i * 0.079);
    var r2 = rng(tSeed * 0.19 + tfSeed * 0.41 + i * 0.053 + 1);
    var trend = Math.sin(i / (count * 0.18) + tSeed * 0.01) * 0.008;
    price = price * (1 + (r1 - 0.48 + trend) * 0.013);
    prices.push(price + (r2 - 0.5) * price * 0.003);
  }
  return prices;
}

function tickerHash(t) {
  var h = 0;
  for (var i = 0; i < t.length; i++) h = ((h * 31 + t.charCodeAt(i)) >>> 0);
  return h;
}

function computeForTicker(ticker) {
  var seed = tickerHash(ticker);
  var result = {};
  for (var i = 0; i < TIMEFRAMES.length; i++) {
    var tf = TIMEFRAMES[i];
    if (tf.paid && !isPaid) { result[tf.id] = null; continue; }
    var prices = generatePrices(seed, tf.tfSeed, tf.bars);
    result[tf.id] = getSignal(computeMACD(prices));
  }
  return result;
}

// ── Rendering ─────────────────────────────────────────────────────────────────
function sigCellHTML(data, locked) {
  if (locked) return '<div class="sc-locked">🔒 PRO</div>';
  if (!data || data.signal === "—") return '<div class="sc neutral"><span class="sc-sig">—</span></div>';
  var cls = data.signal === "BUY" ? "buy" : data.signal === "SELL" ? "sell" : "neutral";
  var zeroCls = data.zero === "ABOVE" ? "above" : "below";
  var zeroTxt = data.zero === "ABOVE" ? "▲ zero" : "▼ zero";
  var hist = data.histogram || 0;
  var pct = Math.min(Math.abs(hist) / (Math.abs(hist) * 3 || 1) * 100, 100);
  var barDir = hist > 0 ? "pos" : "neg";
  return '<div class="sc ' + cls + '">' +
    '<span class="sc-sig">' + data.signal + '</span>' +
    '<span class="sc-zero ' + zeroCls + '">' + zeroTxt + '</span>' +
    '<div class="mbar"><div class="mbar-fill ' + barDir + '" style="width:' + pct + '%"></div></div>' +
    '</div>';
}

function renderTable() {
  var tbody = document.getElementById('signal-tbody');
  var rows = '';
  var totalBuys = 0, totalSells = 0;

  for (var i = 0; i < scrips.length; i++) {
    var ticker = scrips[i];
    var d = allData[ticker] || {};
    var buys = 0, sells = 0;
    for (var j = 0; j < TIMEFRAMES.length; j++) {
      var tf = TIMEFRAMES[j];
      if (tf.paid && !isPaid) continue;
      if (d[tf.id] && d[tf.id].signal === "BUY") buys++;
      if (d[tf.id] && d[tf.id].signal === "SELL") sells++;
    }
    totalBuys += buys; totalSells += sells;
    var smallTxt = buys > sells ? '▲ ' + buys + 'B' : sells > buys ? '▼ ' + sells + 'S' : '—';
    if (buys > 0 && sells > 0) smallTxt = buys + 'B · ' + sells + 'S';

    rows += '<tr>' +
      '<td class="td-ticker">' + ticker + '<small>' + smallTxt + '</small></td>' +
      '<td>' + sigCellHTML(d.monthly, false) + '</td>' +
      '<td>' + sigCellHTML(d.weekly, false) + '</td>' +
      '<td>' + sigCellHTML(d.daily, false) + '</td>' +
      '<td class="td-paid">' + sigCellHTML(d.tf75, !isPaid) + '</td>' +
      '<td class="td-paid">' + sigCellHTML(d.tf15, !isPaid) + '</td>' +
      '<td class="td-paid">' + sigCellHTML(d.tf5, !isPaid) + '</td>' +
      '<td><button class="remove-btn" onclick="removeScrip(\'' + ticker + '\')" title="Remove">×</button></td>' +
      '</tr>';
  }
  tbody.innerHTML = rows;

  document.getElementById('ss-count').textContent = scrips.length + ' scrips';
  document.getElementById('ss-buys').textContent = '▲ ' + totalBuys;
  document.getElementById('ss-sells').textContent = '▼ ' + totalSells;
  document.getElementById('update-stamp').textContent = '↻ ' + new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'});

  renderRecentChips();
  document.getElementById('upgrade-banner').style.display = isPaid ? 'none' : 'flex';
}

function renderRecentChips() {
  var row = document.getElementById('recent-row');
  var chips = scrips.slice(0, 6);
  var html = '<span class="recent-label">RECENT:</span>';
  for (var i = 0; i < chips.length; i++) {
    html += '<span class="recent-chip" onclick="highlightScrip(\'' + chips[i] + '\')">' + chips[i] + '</span>';
  }
  row.innerHTML = html;
}

function highlightScrip(t) {
  // Move to top when clicked
  scrips = [t].concat(scrips.filter(function(x){ return x !== t; }));
  refreshAll();
}

// ── Actions ───────────────────────────────────────────────────────────────────
function refreshAll() {
  for (var i = 0; i < scrips.length; i++) {
    allData[scrips[i]] = computeForTicker(scrips[i]);
  }
  renderTable();
}

function addScrip() {
  var input = document.getElementById('scrip-input');
  var val = input.value.trim().toUpperCase();
  if (!val) return;
  if (scrips.indexOf(val) === -1) {
    scrips.unshift(val);
    if (scrips.length > 20) scrips = scrips.slice(0, 20);
  } else {
    // Move to top
    scrips = [val].concat(scrips.filter(function(x){ return x !== val; }));
  }
  allData[val] = computeForTicker(val);
  input.value = '';
  renderTable();
  input.focus();
}

function removeScrip(ticker) {
  scrips = scrips.filter(function(x){ return x !== ticker; });
  renderTable();
}

function setTier(paid) {
  isPaid = paid;
  document.getElementById('btn-free').className = 'tier-btn free' + (paid ? '' : ' active');
  document.getElementById('btn-pro').className = 'tier-btn pro' + (paid ? ' active' : '');
  refreshAll();
}

// ── Navigation ────────────────────────────────────────────────────────────────
function showPage(id) {
  currentPage = id;
  document.querySelectorAll('.page').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById('page-' + id).classList.add('active');
  document.querySelectorAll('.nav-link').forEach(function(l){ l.classList.remove('active'); });
  var links = document.querySelectorAll('.nav-link');
  var pages = ['home','signals','about'];
  for (var i = 0; i < pages.length; i++) {
    if (pages[i] === id) links[i].classList.add('active');
  }
  if (id === 'signals') renderTable();
}

// ── Init ──────────────────────────────────────────────────────────────────────
refreshAll();
setInterval(refreshAll, 30000);
</script>
</body>
</html>
