<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AI Smart Signal | WaveEdge</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#060a10;--bg2:#0a1018;--bg3:#0d1520;
  --border:#1a2a3a;--border2:#0f1e2d;
  --green:#00e5a0;--green-dim:rgba(0,229,160,0.12);--green-border:rgba(0,229,160,0.25);
  --red:#ff4060;--red-dim:rgba(255,60,80,0.12);--red-border:rgba(255,60,80,0.25);
  --gold:#ffb900;--gold-dim:rgba(255,185,0,0.10);
  --text:#c8d8e8;--text-dim:#5a7090;--text-muted:#2a4060;
  --mono:'Share Tech Mono',monospace;--sans:'Exo 2',sans-serif;
}
html,body{min-height:100vh;background:var(--bg);color:var(--text);font-family:var(--sans);}
body{
  background-image:
    radial-gradient(ellipse at 15% 5%,rgba(0,200,120,0.05) 0%,transparent 45%),
    radial-gradient(ellipse at 85% 90%,rgba(255,60,80,0.04) 0%,transparent 45%);
}

/* NAV */
.nav{display:flex;align-items:center;gap:0;padding:0 20px;height:56px;
  background:var(--bg2);border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:100;}
.nav-logo{font-family:var(--mono);font-size:17px;letter-spacing:3px;color:var(--green);
  text-shadow:0 0 16px rgba(0,229,160,0.35);margin-right:24px;white-space:nowrap;text-decoration:none;}
.nav-logo span{color:var(--red);}
.nav-links{display:flex;gap:2px;flex:1;}
.nav-link{padding:6px 14px;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;
  border-radius:6px;cursor:pointer;color:var(--text-dim);border:1px solid transparent;
  background:none;font-family:var(--sans);transition:all 0.18s;white-space:nowrap;}
.nav-link:hover{color:var(--text);background:rgba(255,255,255,0.04);}
.nav-link.active{color:var(--green);border-color:var(--green-border);background:var(--green-dim);}
.nav-link.pg-signals.active{color:var(--gold);border-color:rgba(255,185,0,0.3);background:var(--gold-dim);}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.live-chip{display:flex;align-items:center;gap:5px;font-family:var(--mono);font-size:10px;color:var(--green);letter-spacing:1px;}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.25}}
.tier-toggle{display:flex;border-radius:6px;overflow:hidden;border:1px solid var(--border);}
.tier-btn{padding:6px 12px;font-family:var(--sans);font-weight:700;font-size:11px;
  letter-spacing:1px;cursor:pointer;border:none;transition:all 0.18s;background:var(--bg3);color:var(--text-dim);}
.tier-btn.free.active{background:var(--green-dim);color:var(--green);}
.tier-btn.pro.active{background:var(--gold-dim);color:var(--gold);}

/* PAGES */
.page{display:none;animation:fadeIn 0.25s ease;}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

/* HOME */
.home-hero{max-width:960px;margin:0 auto;padding:56px 24px 36px;
  display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;}
@media(max-width:700px){.home-hero{grid-template-columns:1fr;padding:36px 16px 20px;}}
.hero-tag{display:inline-block;font-family:var(--mono);font-size:10px;letter-spacing:3px;
  color:var(--green);border:1px solid var(--green-border);padding:4px 10px;border-radius:3px;
  margin-bottom:16px;background:var(--green-dim);}
.hero-title{font-size:40px;font-weight:800;line-height:1.1;margin-bottom:14px;}
.hero-title em{color:var(--green);font-style:normal;}
.hero-sub{font-size:14px;color:var(--text-dim);line-height:1.7;margin-bottom:28px;}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;}
.btn-primary{padding:11px 22px;border-radius:7px;border:none;cursor:pointer;
  font-family:var(--sans);font-weight:700;font-size:14px;background:var(--green);color:#000;transition:opacity 0.18s;}
.btn-primary:hover{opacity:0.85;}
.btn-outline{padding:11px 22px;border-radius:7px;cursor:pointer;font-family:var(--sans);
  font-weight:600;font-size:13px;background:transparent;color:var(--text);
  border:1px solid var(--border);transition:all 0.18s;}
.btn-outline:hover{border-color:var(--green);color:var(--green);}
.hero-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;
  padding:20px;font-family:var(--mono);font-size:12px;line-height:1.8;color:var(--text-dim);
  position:relative;overflow:hidden;}
.hero-card::before{content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(0,229,160,0.04),transparent);pointer-events:none;}
.hero-card-label{font-size:10px;letter-spacing:2px;color:var(--text-muted);margin-bottom:10px;}
.hcr{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--border2);}
.hcr:last-child{border-bottom:none;}
.hcr-tf{color:var(--text-muted);font-size:11px;}
.hcr-buy{color:var(--green);font-weight:700;}
.hcr-sell{color:var(--red);font-weight:700;}
.hcr-za{color:rgba(0,229,160,0.5);font-size:10px;}
.hcr-zb{color:rgba(255,60,80,0.5);font-size:10px;}

.features-grid{max-width:960px;margin:0 auto 60px;padding:0 24px;
  display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
@media(max-width:700px){.features-grid{grid-template-columns:1fr;}}
.feature-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;
  padding:20px;transition:border-color 0.2s;}
.feature-card:hover{border-color:rgba(0,229,160,0.2);}
.fi{font-size:22px;margin-bottom:10px;}
.ft{font-size:14px;font-weight:700;margin-bottom:6px;color:#e0f0ff;}
.fd{font-size:12px;color:var(--text-dim);line-height:1.6;}

/* SIGNAL PAGE */
.sp-wrap{max-width:1020px;margin:0 auto;padding:28px 20px 60px;}
.sp-title-row{display:flex;align-items:baseline;gap:12px;margin-bottom:6px;flex-wrap:wrap;}
.sp-title{font-size:26px;font-weight:800;}
.sp-title em{color:var(--green);font-style:normal;}
.sp-badge{font-family:var(--mono);font-size:10px;letter-spacing:2px;color:var(--green);
  border:1px solid var(--green-border);background:var(--green-dim);padding:3px 8px;border-radius:3px;}
.sp-sub{font-size:11px;color:var(--text-muted);letter-spacing:1px;font-family:var(--mono);margin-bottom:18px;}

/* Summary */
.summary-strip{display:flex;gap:10px;align-items:center;flex-wrap:wrap;
  padding:10px 16px;background:var(--bg2);border:1px solid var(--border);
  border-radius:8px;margin-bottom:18px;}
.ss-label{font-family:var(--mono);font-size:10px;color:var(--text-muted);letter-spacing:1px;}
.ss-val{font-family:var(--mono);font-size:12px;font-weight:700;}
.ss-val.buy{color:var(--green);}
.ss-val.sell{color:var(--red);}
.ss-divider{width:1px;height:18px;background:var(--border);}
.ss-watch{font-family:var(--mono);font-size:14px;font-weight:700;color:#e0f0ff;}
.update-stamp{font-family:var(--mono);font-size:10px;color:var(--text-muted);margin-left:auto;}

/* Controls */
.sp-controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:14px;}
.sp-input{background:var(--bg3);border:1px solid var(--border);color:var(--text);
  padding:9px 12px;border-radius:7px;font-family:var(--mono);font-size:13px;
  outline:none;width:170px;transition:border-color 0.18s;}
.sp-input:focus{border-color:var(--green);}
.sp-input::placeholder{color:var(--text-muted);}
.sp-add-btn{background:var(--green);color:#000;border:none;padding:9px 14px;
  border-radius:7px;font-family:var(--sans);font-weight:700;font-size:13px;cursor:pointer;transition:opacity 0.18s;}
.sp-add-btn:hover{opacity:0.85;}
.sp-refresh{background:var(--bg3);border:1px solid var(--border);color:var(--green);
  padding:9px 12px;border-radius:7px;font-family:var(--sans);font-weight:700;
  font-size:13px;cursor:pointer;transition:all 0.18s;}
.sp-refresh:hover{border-color:var(--green);}

/* Recent chips */
.recent-row{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px;align-items:center;}
.recent-label{font-family:var(--mono);font-size:10px;color:var(--text-muted);letter-spacing:1px;white-space:nowrap;}
.recent-chip{font-family:var(--mono);font-size:11px;letter-spacing:1px;padding:3px 9px;
  border-radius:4px;cursor:pointer;border:1px solid var(--border);background:var(--bg3);
  color:var(--text-dim);transition:all 0.15s;}
.recent-chip:hover{border-color:var(--green);color:var(--green);}

/* Upgrade banner */
.upgrade-banner{background:linear-gradient(135deg,#120e00,#0d0900);
  border:1px solid #2a1e00;border-radius:10px;padding:14px 18px;
  display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:18px;}
.ub-icon{font-size:20px;}
.ub-text{flex:1;}
.ub-text strong{color:var(--gold);font-size:13px;}
.ub-text p{font-size:11px;color:#5a4010;margin-top:2px;}
.ub-btn{background:linear-gradient(135deg,#b88000,#ffb900);color:#000;border:none;
  padding:9px 16px;border-radius:6px;font-family:var(--sans);font-weight:700;
  font-size:12px;cursor:pointer;white-space:nowrap;transition:opacity 0.18s;}
.ub-btn:hover{opacity:0.85;}

/* Table */
.main-table-wrap{border-radius:12px;overflow:hidden;border:1px solid var(--border);
  box-shadow:0 8px 40px rgba(0,0,0,0.5);margin-bottom:18px;overflow-x:auto;}
.main-table{width:100%;border-collapse:collapse;min-width:600px;}
.main-table thead tr{background:#080f18;}
.main-table th{padding:11px 6px;font-size:10px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;color:var(--text-muted);text-align:center;border-bottom:1px solid var(--border);}
.main-table th.th-left{text-align:left;padding-left:16px;}
.main-table th.th-paid{color:rgba(255,185,0,0.5);border-left:2px solid rgba(255,185,0,0.12);}
.main-table tbody tr{border-bottom:1px solid var(--border2);transition:background 0.12s;}
.main-table tbody tr:hover{background:rgba(0,229,160,0.025);}
.main-table tbody tr:last-child{border-bottom:none;}
.main-table td{padding:9px 5px;text-align:center;vertical-align:middle;}
.main-table td.td-ticker{font-family:var(--mono);font-size:13px;font-weight:700;color:#e0f0ff;
  letter-spacing:2px;text-align:left;padding-left:16px;background:var(--bg2);white-space:nowrap;}
.main-table td.td-ticker small{display:block;font-size:9px;color:var(--text-muted);letter-spacing:1px;margin-top:1px;}
.main-table td.td-paid{border-left:2px solid rgba(255,185,0,0.1);}
.remove-btn{background:none;border:none;color:var(--text-muted);cursor:pointer;
  font-size:16px;padding:2px 6px;border-radius:4px;transition:color 0.15s;line-height:1;}
.remove-btn:hover{color:var(--red);}

/* Signal cell */
.sc{display:flex;flex-direction:column;align-items:center;gap:2px;}
.sc-sig{font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:0.5px;
  padding:2px 7px;border-radius:3px;white-space:nowrap;}
.sc.buy .sc-sig{background:var(--green-dim);color:var(--green);border:1px solid var(--green-border);}
.sc.sell .sc-sig{background:var(--red-dim);color:var(--red);border:1px solid var(--red-border);}
.sc.neutral .sc-sig{background:rgba(90,120,150,0.08);color:#3a5a7a;border:1px solid rgba(90,120,150,0.15);}
.sc-zero{font-size:9px;letter-spacing:0.5px;}
.sc-zero.above{color:rgba(0,229,160,0.5);}
.sc-zero.below{color:rgba(255,60,80,0.45);}
.sc-locked{display:flex;align-items:center;justify-content:center;gap:3px;
  font-family:var(--mono);font-size:9px;color:rgba(255,185,0,0.4);letter-spacing:1px;}
.mbar{width:30px;height:3px;background:#0d1520;border-radius:2px;overflow:hidden;margin-top:2px;}
.mbar-fill{height:100%;border-radius:2px;}
.mbar-fill.pos{background:var(--green);}
.mbar-fill.neg{background:var(--red);}

/* ABOUT */
.about-wrap{max-width:760px;margin:0 auto;padding:48px 24px 60px;}
.about-section{margin-bottom:36px;}
.about-h{font-size:20px;font-weight:700;color:#e0f0ff;margin-bottom:12px;
  padding-bottom:8px;border-bottom:1px solid var(--border);}
.about-p{font-size:14px;color:var(--text-dim);line-height:1.8;margin-bottom:12px;}
.about-table{width:100%;border-collapse:collapse;font-size:13px;margin-top:10px;}
.about-table th{text-align:left;padding:8px 12px;background:var(--bg2);
  color:var(--text-muted);font-size:11px;letter-spacing:1px;border-bottom:1px solid var(--border);}
.about-table td{padding:9px 12px;border-bottom:1px solid var(--border2);color:var(--text-dim);}
.about-table td:first-child{font-family:var(--mono);color:#e0f0ff;}

/* Footer */
.sp-footer{font-family:var(--mono);font-size:10px;color:var(--text-muted);
  text-align:center;letter-spacing:1px;padding-top:10px;}

@media(max-width:640px){
  .sp-title{font-size:20px;}
  .main-table td.td-ticker{font-size:11px;}
  .sc-sig{font-size:9px;}
  .sp-input{width:130px;}
  .nav-logo{font-size:14px;margin-right:12px;}
}
</style>
</head>
